# Production env for setadjang.ir
# Copy to .env.production (or set in the deployment platform) before
# `npm run build`. None of these values is secret — they all become
# part of the client bundle via Next's NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_SITE_URL=https://setadjang.ir
NEXT_PUBLIC_API_URL=https://api.setadjang.ir
