# ────────────────────────────────────────────────────────────────────
#  Setad-Jang Frontend — environment template
# ────────────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` for local dev, or set these
#  variables in the deployment platform for staging / production.
#  All NEXT_PUBLIC_* keys end up in the client bundle at build time.
# ────────────────────────────────────────────────────────────────────

# Public site URL — used for canonical/OG/sitemap/JSON-LD metadata.
#   local dev  : http://localhost:3000
#   staging    : http://188.253.2.86:3000
#   production : https://setadjang.ir
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base URL — WITHOUT the /api/v1 suffix.
#   local dev  : http://127.0.0.1:8000
#   staging    : http://188.253.2.86:18080
#   production : https://api.setadjang.ir
# The `/api/v1` prefix is appended automatically by the API client
# (src/lib/api.ts) and the Next.js rewrite (`/api/proxy/*`) in
# next.config.mjs.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional — Google Tag Manager container id (leave blank to disable)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=false
